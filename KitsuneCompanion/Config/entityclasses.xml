<?xml version="1.0" encoding="UTF-8" ?>
<configs>

    <append xpath="/entity_classes">

        <entity_class name="kitsuneCompanion" extends="animalCoyote">

            <property name="Tags" value="entity,animal,companion,fox,kitsune" />
            <property name="UserSpawnType" value="Menu" />
            <property name="IsEnemyEntity" value="false" />

            <property name="MapIcon" value="" />
            <property name="TrackerIcon" value="" />
            <property name="CompassIcon" value="" />
            <property name="CompassUpIcon" value="" />
            <property name="CompassDownIcon" value="" />
            <property name="NavObject" value="" />

            <property name="Mass" value="60" />
            <property name="Weight" value="60" />
            <property name="SizeScale" value="0.75" />

            <property name="MoveSpeed" value="0.55" />
            <property name="MoveSpeedAggro" value="1.6" />
            <property name="MoveSpeedRun" value="1.35" />
            <property name="MoveSpeedPanic" value="1.7" />
            <property name="JumpStrength" value="2.4" />
            <property name="JumpMaxDistance" value="3" />

            <property name="ExperienceGain" value="0" />
            <property name="LootListOnDeath" value="" />

            <!-- Task slots inherit from animalCoyote / animalWolf except the
                 AttackTarget filter which we override to remove EntityPlayer.
                 We deliberately do NOT set AITask-2 / AITask-3 to empty —
                 the V2.6 AI parser treats an empty value as "stop iterating
                 tasks" rather than "skip slot," which silently breaks
                 ApproachSpot (slot 5) and we lose follow entirely.
                 Companion side-effects of inherited Territorial /
                 RunawayWhenHurt are minor and can be tuned later. -->
            <property name="AITask-4" value="ApproachAndAttackTarget" data="class=EntityZombie,20,EntityBandit,15" />

            <!-- Same caveat: inherit AITarget slots from coyote/wolf except
                 the SetNearestEntityAsTarget filter (remove EntityPlayer
                 from attack-target list). Don't blank slot 4. -->
            <property name="AITarget-3" value="SetNearestEntityAsTarget" data="class=EntityZombie,0,-8,EntityBandit,0,-8" />

            <effect_group name="Base Effects">
                <passive_effect name="HealthMax" operation="base_set" value="120" />
            </effect_group>

        </entity_class>

    </append>

</configs>
