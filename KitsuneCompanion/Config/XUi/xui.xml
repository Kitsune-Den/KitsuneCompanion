<?xml version="1.0" encoding="UTF-8" ?>
<configs>

    <!-- Register HUDKitsuneStatusStrip in the toolbelt window_group so the
         XUi system actually instantiates it. Defining the window in
         windows.xml alone is not enough — it has to be a member of an
         instantiated window_group. The 'toolbelt' group has actionSet="false"
         (always-on overlay), which is what we want for a HUD strip. -->
    <append xpath="/xui/ruleset[@name='default']/window_group[@name='toolbelt']">
        <window name="HUDKitsuneStatusStrip" />
    </append>

    <!-- Register kitsune companion panel on the crafting window_group.
         Crafting is the default tab Tab opens, AND its right column is
         empty (character tab has Status Effects there which overlaps).
         Also register on character group so it's available on both tabs;
         on character tab it'll overlap Status Effects until we tune the
         positioning. -->
    <append xpath="/xui/ruleset[@name='default']/window_group[@name='crafting']">
        <window name="windowKitsuneCompanionPanel" />
    </append>
    <append xpath="/xui/ruleset[@name='default']/window_group[@name='character']">
        <window name="windowKitsuneCompanionPanel" />
    </append>

</configs>
