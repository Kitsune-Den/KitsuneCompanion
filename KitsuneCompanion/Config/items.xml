            <property name="Weight" value="2"/>
            <property name="Stacknumber" value="10"/>
            <property name="EconomicValue" value="800"/>
            <property name="Group" value="Resources"/>
        </item>

        <!-- Bond Charm. Consumed by the temperament manager when a player
             carrying it stands within 8 blocks of a kitsune; grants +25 bond
             points to that kitsune. See CompanionTicker.TryConsumeBondCharm. -->
        <item name="kitsuneBondCharm">
            <property name="HoldType" value="45"/>
            <property name="Tags" value="junk,kitsuneRitualItem,kitsuneBondCharm"/>
            <property name="Meshfile" value="@:Other/Items/Misc/sackPrefab.prefab"/>
