            <property name="Group" value="Resources"/>
        </item>

        <!-- Mist evolution talisman. Consumed by the temperament manager when
             a player carrying it stands within 8 blocks of a kitsune. -->
        <item name="kitsuneMistTalisman">
            <property name="HoldType" value="45"/>
            <property name="Tags" value="junk,kitsuneRitualItem,kitsuneFormTalisman"/>
            <property name="Meshfile" value="@:Other/Items/Misc/sackPrefab.prefab"/>
            <property name="DropMeshfile" value="@:Other/Items/Misc/sack_droppedPrefab.prefab"/>
